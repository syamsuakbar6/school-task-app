DATABASE_URL=postgresql://postgres:<YOUR_DB_PASSWORD>@localhost:5432/school_db
SECRET_KEY=change-this-to-a-long-random-jwt-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

STORAGE_BACKEND=supabase
STORAGE_DIR=uploads/submissions
MAX_UPLOAD_SIZE_MB=5
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.png,.jpg,.jpeg,.txt,.zip

# Supabase Storage (wajib diisi di production)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_BUCKET=submissions
